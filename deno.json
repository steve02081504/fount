{
	"nodeModulesDir": "auto",
	"lock": false,
	"unstable": [
		"npm-lazy-caching"
	],
	"tasks": {
		"run": "deno run -A path/fount.mjs run",
		"init": "deno run -A path/fount.mjs init",
		"debug": "deno run -A path/fount.mjs debug",
		"shutdown": "deno run -A path/fount.mjs shutdown",
		"reboot": "deno run -A path/fount.mjs reboot",
		"clean": "deno run -A path/fount.mjs clean",
		"update": "git pull -f --rebase origin master",
		"geneexe": "deno run -A path/fount.mjs geneexe",
		"remove": "deno run -A path/fount.mjs remove",
		"nop": "deno run -A path/fount.mjs nop",

		"start": "deno run -A path/fount.mjs",
		"stop": "deno run -A path/fount.mjs shutdown",
		"restart": "deno run -A path/fount.mjs reboot",
		"dev": "deno run -A path/fount.mjs debug",
		"uninstall": "deno run -A path/fount.mjs remove"
	},
	"imports": {
		"npm:estree": "npm:nop",
		"npm:express": "npm:express@^5.1.0",
		"npm:express-fileupload": "npm:express-fileupload@^1.5.0",
		"npm:cookie-parser": "npm:cookie-parser@^1.4.0",
		"npm:@steve02081504/virtual-console": "npm:@steve02081504/virtual-console@^0.2.0",
		"npm:on-shutdown": "npm:on-shutdown@^0.0.3",
		"npm:fs-extra": "npm:fs-extra@^11.3.2",
		"npm:file-type": "npm:file-type@^21.0.0"
	},
	"lint": {
		"exclude": [
			"src/public/pages/",
			".github/pages/",
			"src/public/parts/shells/*/public/**"
		],
		"rules": {
			"exclude": [
				"no-unversioned-import",
				"no-import-prefix"
			]
		}
	}
}
