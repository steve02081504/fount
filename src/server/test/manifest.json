{
	"id": "server",
	"suites": [
		{
			"name": "pure",
			"run": [
				"deno", "test", "--no-check", "--allow-all", "-c", "./deno.json",
				"./src/server/test/pure/"
			],
			"triggers": [
				"src/server/test/pure/**",
				"src/server/registries.mjs",
				"src/public/pages/scripts/api/registries.mjs"
			]
		},
		{
			"name": "live",
			"run": [
				"deno", "test", "--no-check", "--allow-all", "-c", "./deno.json",
				"./src/server/test/live/"
			],
			"triggers": [
				"src/server/test/live/**",
				"src/server/**",
				"src/scripts/test/node/**",
				"src/scripts/WsAbleRouter.mjs",
				"src/scripts/ms.mjs",
				"src/server/web_server/resources.mjs"
			]
		}
	]
}
