{
	"id": "shells/social",
	"triggerSets": {
		"shellPure": [
			"src/public/parts/shells/social/**",
			"src/public/parts/shells/chat/public/markdown_ext/**",
			"src/scripts/p2p/**",
			"src/server/p2p_server/**",
			"src/server/registries.mjs",
			"src/public/pages/scripts/api/registries.mjs",
			"src/public/pages/scripts/components/emojiPicker.mjs",
			"src/public/pages/scripts/components/stickerPicker.mjs",
			"src/public/pages/scripts/features/markdown/extensions.mjs"
		],
		"shellIntegration": [
			"src/public/parts/shells/social/**",
			"src/public/parts/shells/chat/public/markdown_ext/**",
			"src/public/parts/shells/chat/src/group/groupPreview.mjs",
			"src/public/parts/shells/chat/src/group/emojiContentResolve.mjs",
			"src/scripts/p2p/**",
			"src/server/p2p_server/**",
			"src/server/registries.mjs",
			"src/public/pages/scripts/api/registries.mjs",
			"src/public/pages/scripts/components/emojiPicker.mjs",
			"src/public/pages/scripts/components/stickerPicker.mjs",
			"src/public/pages/scripts/features/markdown/extensions.mjs"
		],
		"shellLive": [
			"src/public/parts/shells/social/**"
		],
		"ws": [
			"src/public/parts/shells/social/**",
			"src/server/registries.mjs",
			"src/public/pages/scripts/api/registries.mjs"
		],
		"crossShellEmoji": [
			"src/public/parts/shells/social/**",
			"src/public/parts/shells/chat/public/markdown_ext/**",
			"src/public/parts/shells/chat/src/group/groupPreview.mjs",
			"src/public/parts/shells/chat/src/group/emojiContentResolve.mjs",
			"src/server/registries.mjs",
			"src/public/pages/scripts/api/registries.mjs",
			"src/public/pages/scripts/components/emojiPicker.mjs"
		],
		"frontend": [
			"src/public/parts/shells/social/public/**",
			"src/public/parts/shells/social/test/frontend/**",
			"src/scripts/test/playwright/**",
			"src/public/pages/scripts/test/ready_gate.mjs",
			"src/server/auth/index.mjs",
			"src/server/web_server/endpoints.mjs"
		]
	},
	"suites": [
		{
			"name": "pure",
			"trigger": "shellPure",
			"run": [
				"deno", "run", "--allow-all", "-c", "./deno.json",
				"./src/scripts/test/deno/serial.mjs",
				"./src/public/parts/shells/social/test/pure/"
			]
		},
		{
			"name": "integration",
			"dependsOn": ["server:live"],
			"trigger": "shellIntegration",
			"run": [
				"deno", "run", "--allow-all", "-c", "./deno.json",
				"./src/scripts/test/deno/serial.mjs",
				"./src/public/parts/shells/social/test/integration/"
			]
		},
		{ "name": "smoke_social", "dependsOn": ["server:live"], "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/social/test/live/run.mjs", "--suite", "smoke_social"], "trigger": "shellLive" },
		{ "name": "e2e_single", "dependsOn": ["server:live", "smoke_social"], "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/social/test/live/run.mjs", "--suite", "e2e_single"], "trigger": "shellLive" },
		{ "name": "ws", "dependsOn": ["server:live", "smoke_social"], "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/social/test/live/run.mjs", "--suite", "ws"], "trigger": "ws" },
		{ "name": "cross_shell_emoji", "dependsOn": ["server:live", "smoke_social", "shells/chat:fed_core", "shells/chat:fed_emoji"], "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/social/test/live/run.mjs", "--suite", "cross_shell_emoji"], "trigger": "crossShellEmoji" },
		{ "name": "frontend", "dependsOn": ["server:live", "smoke_social", "e2e_single"], "run": ["deno", "run", "-A", "-c", "./deno.json", "./src/public/parts/shells/social/test/frontend/run.mjs"], "trigger": "frontend" }
	]
}
