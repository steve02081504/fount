{
	"id": "shells/chat",
	"triggerSets": {
		"shellPure": [
			"src/public/parts/shells/chat/**",
			"src/public/parts/shells/social/src/lib/emojiPostEmbed.mjs",
			"src/scripts/p2p/**",
			"src/server/p2p_server/**",
			"src/server/registries.mjs",
			"src/server/parts_loader.mjs",
			"src/public/pages/scripts/api/registries.mjs",
			"src/public/pages/scripts/features/markdown/extensions.mjs",
			"src/public/pages/scripts/components/emojiPicker.mjs",
			"src/public/pages/scripts/components/stickerPicker.mjs"
		],
		"shellIntegration": [
			"src/public/parts/shells/chat/**",
			"src/scripts/p2p/**",
			"src/server/p2p_server/**",
			"src/server/registries.mjs",
			"src/server/parts_loader.mjs",
			"src/public/pages/scripts/api/registries.mjs",
			"src/public/pages/scripts/features/markdown/extensions.mjs",
			"src/public/pages/scripts/components/emojiPicker.mjs",
			"src/public/pages/scripts/components/stickerPicker.mjs"
		],
		"shellLive": [
			"src/public/parts/shells/chat/**",
			"src/server/registries.mjs",
			"src/server/parts_loader.mjs",
			"src/public/pages/scripts/api/registries.mjs",
			"src/public/pages/scripts/features/markdown/extensions.mjs",
			"src/public/pages/scripts/components/emojiPicker.mjs",
			"src/public/pages/scripts/components/stickerPicker.mjs"
		],
		"fed": [
			"src/public/parts/shells/chat/src/chat/federation/**"
		],
		"fedArchive": [
			"src/public/parts/shells/chat/src/chat/federation/**",
			"src/public/parts/shells/chat/src/chat/archive/**"
		],
		"fedMailbox": [
			"src/public/parts/shells/chat/src/chat/federation/**",
			"src/public/parts/shells/chat/src/chat/mailbox/**"
		],
		"fedEmoji": [
			"src/public/parts/shells/chat/src/chat/federation/**",
			"src/public/parts/shells/chat/src/group/emojiContentResolve.mjs",
			"src/public/parts/shells/chat/src/group/groupPreview.mjs"
		],
		"fedEmojiGroup": [
			"src/public/parts/shells/chat/src/group/**",
			"src/server/registries.mjs"
		],
		"fedEmojiNearcache": [
			"src/public/parts/shells/chat/src/group/**",
			"src/scripts/p2p/files/**"
		],
		"fedFileTransfer": [
			"src/public/parts/shells/chat/src/chat/federation/**",
			"src/scripts/p2p/files/**"
		],
		"frontend": [
			"src/public/parts/shells/chat/public/**",
			"src/public/parts/shells/chat/test/frontend/**",
			"src/scripts/test/playwright/**",
			"src/public/pages/scripts/test/ready_gate.mjs",
			"src/server/auth/index.mjs",
			"src/server/web_server/endpoints.mjs"
		]
	},
	"suites": [
		{
			"name": "pure",
			"trigger": "shellPure",
			"run": [
				"deno", "run", "--allow-all", "-c", "./deno.json",
				"./src/scripts/test/deno/serial.mjs",
				"./src/public/parts/shells/chat/test/pure/"
			]
		},
		{
			"name": "integration",
			"dependsOn": ["server:live"],
			"trigger": "shellIntegration",
			"run": [
				"deno", "run", "--allow-all", "-c", "./deno.json",
				"./src/scripts/test/deno/serial.mjs",
				"./src/public/parts/shells/chat/test/integration/"
			]
		},
		{ "name": "e2e_single", "dependsOn": ["server:live", "smoke_chat"], "trigger": "shellLive", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "e2e_single"] },
		{ "name": "e2e_single_ext", "dependsOn": ["server:live", "e2e_single"], "trigger": "shellLive", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "e2e_single_ext"] },
		{ "name": "smoke_chat", "dependsOn": ["server:live"], "trigger": "shellLive", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "smoke_chat"] },
		{ "name": "smoke_ai", "dependsOn": ["server:live", "smoke_chat"], "trigger": "shellLive", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "smoke_ai"] },
		{ "name": "ws", "dependsOn": ["server:live", "smoke_chat"], "trigger": "shellLive", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "ws"] },
		{ "name": "ws_rpc", "dependsOn": ["server:live", "ws"], "trigger": "shellLive", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "ws_rpc"] },
		{ "name": "ws_stream", "dependsOn": ["server:live", "ws_rpc"], "trigger": "shellLive", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "ws_stream"] },
		{ "name": "av_relay", "dependsOn": ["server:live", "ws"], "trigger": "shellLive", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "av_relay"] },
		{ "name": "fed_core", "dependsOn": ["server:live", "p2p:sim", "p2p:live"], "trigger": "fed", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "fed_core"] },
		{ "name": "fed_e2e_ext", "dependsOn": ["fed_core"], "trigger": "fed", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "fed_e2e_ext"] },
		{ "name": "fed_dm", "dependsOn": ["fed_core"], "trigger": "fed", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "fed_dm"] },
		{ "name": "fed_archive_month", "dependsOn": ["fed_core"], "trigger": "fedArchive", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "fed_archive_month"] },
		{ "name": "fed_mailbox", "dependsOn": ["fed_core"], "trigger": "fedMailbox", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "fed_mailbox"] },
		{ "name": "fed_ban", "dependsOn": ["fed_core"], "trigger": "fed", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "fed_ban"] },
		{ "name": "fed_emoji", "dependsOn": ["fed_core"], "trigger": "fedEmoji", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "fed_emoji"] },
		{ "name": "fed_emoji_nonmember", "dependsOn": ["fed_core", "fed_emoji"], "trigger": "fedEmojiGroup", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "fed_emoji_nonmember"] },
		{ "name": "fed_emoji_nearcache", "dependsOn": ["fed_core", "fed_emoji"], "trigger": "fedEmojiNearcache", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "fed_emoji_nearcache"] },
		{ "name": "fed_file_transfer", "dependsOn": ["fed_core"], "trigger": "fedFileTransfer", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "fed_file_transfer"] },
		{ "name": "fed_control_plane", "dependsOn": ["fed_core"], "trigger": "fed", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "fed_control_plane"] },
		{ "name": "fed_reputation_owner", "dependsOn": ["fed_core"], "trigger": "fed", "run": ["deno", "run", "--allow-all", "-c", "./deno.json", "./src/public/parts/shells/chat/test/live/run.mjs", "--suite", "fed_reputation_owner"] },
		{ "name": "frontend", "dependsOn": ["server:live", "e2e_single"], "trigger": "frontend", "run": ["deno", "run", "-A", "-c", "./deno.json", "./src/public/parts/shells/chat/test/frontend/run.mjs"] }
	]
}
